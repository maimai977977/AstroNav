---
// src/layouts/BaseLayout.astro
import '../styles/global.css'
import NavCard from '../components/NavCard.astro';
import navData from '../data/Navdata.json';   

export interface Props {
  title?: string;
}

const { title = "MaiMaiNav" } = Astro.props;

// 提取所有不重复的分类（过滤掉空值），并添加“全部”
const categories = ['全部', ...new Set(navData.map(item => item.category).filter(Boolean))];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Astro + Tailwind 布局示例" />
    <!-- 引入 Alpine.js CDN（用于侧边栏折叠） -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <div x-data="{ sidebarOpen: true }" class="flex flex-col min-h-screen">
      
      <!-- 顶部导航栏（保持不变） -->
      <header class="fixed top-0 left-0 right-0 z-20 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 shadow-sm">
        <div class="flex items-center justify-between h-16 px-4 lg:px-6">
          <div class="flex items-center gap-3">
            <button @click="sidebarOpen = !sidebarOpen" class="p-2 rounded-md text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700">
              <svg x-show="!sidebarOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
              <svg x-show="sidebarOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4L4 8l4 4" /></svg>
            </button>
            <span class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">MaimaiNav</span>
            <span class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent" id="dailyQuote"></span>
          </div>
                    <!-- 美化搜索框 + QQ头像（圆形旋转） -->
<div class="flex items-center gap-3">
      <!-- 夸克网盘资源入口按钮 -->
  <a 
  href="/AstroNav/table" 
  class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
  title="夸克网盘资源库"
>
  <svg class="w-5 h-5 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2 1.5 4 4 4h8c2.5 0 4-2 4-4V7M4 7h16M4 7l4-4h8l4 4" />
  </svg>
</a>
    <!-- 文件夹视图入口按钮 -->
  <a 
    href="/AstroNav/folder" 
    class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
    title="GO MY FOLDER"
  >
    <svg class="w-5 h-5 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
    </svg>
  </a>
 <!-- 搜索框 -->
  <div class="relative">
    <input
      type="text"
      id="searchInput"
      placeholder="搜索网站..."
      class="w-48 sm:w-64 pl-9 pr-4 py-2 text-sm bg-gray-100 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
      autocomplete="off"
    />
    <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </div>

  <!-- QQ头像（圆形，悬停旋转） -->
  <div class="group relative">
    <img
      id="qqAvatar"
      src="https://q1.qlogo.cn/g?b=qq&nk=80000000&s=100"
      alt="QQ头像"
      class="w-9 h-9 rounded-full border-2 border-blue-500 shadow-md transition-transform duration-500 group-hover:rotate-180 cursor-pointer"
      onerror="this.src='https://placehold.co/100x100/3b82f6/white?text=QQ'"
    />
    <!-- 可选：悬停提示 -->
    <div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 translate-y-full mt-1 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none text-xs bg-gray-800 text-white px-2 py-1 rounded whitespace-nowrap">
      点击切换
    </div>
  </div>
</div>
        </div>
      </header>

      <!-- 主体布局 -->
      <div class="flex flex-1 pt-16">
        <!-- 侧边栏 -->
        <aside
 x-show="sidebarOpen"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="-translate-x-full"
  x-transition:enter-end="translate-x-0"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="translate-x-0"
  x-transition:leave-end="-translate-x-full"
  class="fixed left-0 top-16 z-20 w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 h-[calc(100vh-4rem)] overflow-y-auto shadow-lg"
        >
          <nav class="p-4 space-y-1">
            {categories.map(cat => {
              // 计算 href：分类名为“全部”时 hash 为空，否则为 #分类名
              const hash = cat === '全部' ? '' : cat;
              return (
                <a
                  href={hash ? `#${encodeURIComponent(hash)}` : '#'}
                  class="nav-link flex items-center gap-3 px-4 py-2 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700"
                  data-category={cat}
                >
                  {cat}
                </a>
              );
            })}
          </nav>
        </aside>

        <!-- 右侧内容区域 -->
        <main class="flex-1 p-6 overflow-x-auto">
   <!-- 右侧内容区域：动态添加左边距，避免被固定侧边栏遮挡 -->
<main 
  class="flex-1 p-6 overflow-x-auto transition-all duration-300"
  :class="{ 'lg:pl-64': sidebarOpen, 'lg:pl-0': !sidebarOpen }"
>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="card-grid">
    {navData.map(item => (
      <div class="card-item" data-category={item.category}>
        <NavCard 
            id={item.id as number}
            title={item.title as string}
            description={item.description as string}
            tags={item.tags as string[]}
            status={item.status as "online" | "offline"}
            url={item.url as string}
            image={item.image as string}
        />
      </div>
    ))}
  </div>
</main>
      </div>

<footer class="relative mt-12 overflow-hidden bg-gradient-to-r from-gray-900 via-indigo-900 to-purple-900 dark:from-gray-950 dark:via-indigo-950 dark:to-purple-950 border-t border-white/10 shadow-inner">

  <!-- 动态流光线条 -->
  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full animate-[shimmer_3s_infinite]"></div>
  
  <div class="container mx-auto px-4 py-4 relative z-10">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <!-- Logo 区（简化） -->
      <div class="flex items-center gap-2">
        <span class="text-lg font-black bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-500 bg-clip-text text-transparent">
          MaimaiNav
        </span>
        <span class="text-xs text-cyan-400/70 animate-pulse">✨</span>
      </div>
      <!-- 社交图标（紧凑） -->
      <div class="flex gap-3">
        <a href="#" class="group w-8 h-8 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-cyan-500 transition-all duration-300 hover:scale-110">
          <svg class="w-4 h-4 text-white/80 group-hover:text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
          </svg>
        </a>
        <a href="#" class="group w-8 h-8 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-cyan-500 transition-all duration-300 hover:scale-110">
          <svg class="w-4 h-4 text-white/80 group-hover:text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
          </svg>
        </a>
        <a href="#" class="group w-8 h-8 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-cyan-500 transition-all duration-300 hover:scale-110">
          <svg class="w-4 h-4 text-white/80 group-hover:text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.04C6.5 2.04 2 6.53 2 12.06c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.76c-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02.8-.22 1.65-.33 2.5-.33.85 0 1.7.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.56 4.94.36.31.68.92.68 1.86v2.75c0 .27.16.59.67.5C19.14 20.22 22 16.48 22 12.06c0-5.53-4.5-10.02-10-10.02z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- 版权行（更紧凑） -->
    <div class="flex flex-wrap items-center justify-between gap-2 mt-2 text-center">
      <p class="text-xs text-white/60 hover:text-white/90 transition">
        © 2026 MaimaiNav. All rights reserved.
      </p>
      <p class="text-[11px] text-white/40 font-mono">
        ❤️ Efficiency
      </p>
    </div>
  </div>

  <!-- 底部边缘发光（保留） -->
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-cyan-500 to-transparent"></div>
</footer>


 <!-- 返回顶部按钮（美化版） -->
<div id="back-to-top" class="fixed bottom-6 right-6 z-30 opacity-0 invisible transition-all duration-300">
  <button 
    onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    class="group relative p-3 bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 focus:outline-none backdrop-blur-sm"
    aria-label="返回顶部"
  >
    <!-- 箭头图标 + hover 上移动画 -->
    <svg class="w-5 h-5 transition-transform duration-300 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
    <!-- 可选：轻微内发光效果 -->
    <span class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-[inset_0_0_12px_rgba(255,255,255,0.3)]"></span>
  </button>
</div>
    <script>
  // ========== 分类 + 搜索联合过滤 ==========
  function filterAndHighlight() {
    // 获取当前分类（从 hash 中读取）
    let hash = window.location.hash.slice(1);
    hash = decodeURIComponent(hash);
    const currentCategory = hash || '全部';

    // 获取搜索词（小写）
const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';

    // 1. 过滤卡片
    const cards = document.querySelectorAll('.card-item');
    cards.forEach(card => {
      const cardCategory = card.getAttribute('data-category');
      // 分类匹配
      const categoryMatch = (currentCategory === '全部' || cardCategory === currentCategory);
      // 搜索匹配（检查标题和描述）
      let searchMatch = true;
      if (searchTerm) {
        const titleEl = card.querySelector('h3');
        const descEl = card.querySelector('p');
        const title = titleEl ? titleEl.textContent.toLowerCase() : '';
        const desc = descEl ? descEl.textContent.toLowerCase() : '';
        searchMatch = title.includes(searchTerm) || desc.includes(searchTerm);
      }
      (card as HTMLElement).style.display = (categoryMatch && searchMatch) ? '' : 'none';
    });

    // 2. 高亮当前菜单（保持原有样式）
    const links = document.querySelectorAll('.nav-link');
    links.forEach(link => {
      const linkCategory = link.getAttribute('data-category');
      if (linkCategory === currentCategory) {
        link.classList.add('bg-gray-100', 'dark:bg-gray-700');
      } else {
        link.classList.remove('bg-gray-100', 'dark:bg-gray-700');
      }
    });
  }

  // 监听 hash 变化
  window.addEventListener('hashchange', filterAndHighlight);
  // 页面加载时执行一次
  window.addEventListener('DOMContentLoaded', filterAndHighlight);

  // 监听搜索框输入
  const searchInput = document.getElementById('searchInput');
  if (searchInput) {
    searchInput.addEventListener('input', filterAndHighlight);
  }

  // ========== QQ 头像旋转与更换（可选） ==========
  const qqAvatar = document.getElementById('qqAvatar');
  if (qqAvatar) {
    qqAvatar.addEventListener('click', () => {
      const newQQ = prompt('请输入新的QQ号码', '949022711');
      if (newQQ && /^\d{5,11}$/.test(newQQ)) {
        const qqAvatar = document.getElementById('qqAvatar') as HTMLImageElement | null;
if (qqAvatar) {
  qqAvatar.src = `https://q1.qlogo.cn/g?b=qq&nk=${newQQ}&s=100`;
}
      } else if (newQQ) {
        alert('请输入有效的QQ号码（5-11位数字）');
      }
    });
  }

  // ========== 返回顶部按钮逻辑（保留） ==========
  const backToTopBtn = document.getElementById('back-to-top');
  if (backToTopBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        backToTopBtn.classList.remove('opacity-0', 'invisible');
        backToTopBtn.classList.add('opacity-100', 'visible');
      } else {
        backToTopBtn.classList.add('opacity-0', 'invisible');
        backToTopBtn.classList.remove('opacity-100', 'visible');
      }
    });
  }

  // ========== 每日美句（保留，不动原逻辑） ==========
  const quoteEl = document.getElementById('dailyQuote');
  if (quoteEl) {
    quoteEl.textContent = '✨ 加载中...';
    fetch('https://v1.hitokoto.cn/')
      .then(res => res.json())
      .then(data => {
        quoteEl.textContent = `「${data.hitokoto}」${data.from ? ` —— 《${data.from}》` : ''}`;
      })
      .catch(() => {
        quoteEl.textContent = '✨ 长风破浪会有时，直挂云帆济沧海。';
      });
  }

  
  
</script>
<!-- 动画（只需保留 shimmer） -->
<style>
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .animate-shimmer {
    animation: shimmer 3s infinite linear;
  }
</style>
  </body>
</html>