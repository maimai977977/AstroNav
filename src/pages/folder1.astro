---
// src/pages/folder.astro
import FolderLayout from '../layouts/FolderLayout.astro';
import roomData from '../data/roomdata.json';

interface NavItem {
  id: number;
  category: string;
  title: string;
  description: string;
  tags: string[];
  status: string;
  url: string;
  image: string;
}

// 确保数据存在
const safeData = Array.isArray(roomData) ? roomData : [];

const groupedItems = safeData.reduce((acc, item) => {
  const folderName = item.category || '未分类';
  if (!acc[folderName]) acc[folderName] = [];
  acc[folderName].push(item);
  return acc;
}, {} as Record<string, NavItem[]>);

// 将数据转换为安全的 JSON 字符串（用于客户端）
const safeDataJson = JSON.stringify(safeData);
const groupedJson = JSON.stringify(groupedItems);
const categoriesCount = Object.keys(groupedItems).length;
const totalCount = safeData.length;
---

<FolderLayout title="MaiMai · 资源库">
  <!-- 动态渐变背景 Canvas -->
  <canvas id="gradientCanvas" class="fixed top-0 left-0 w-full h-full -z-10"></canvas>
  
  <div class="relative z-10 min-h-screen text-slate-200 antialiased backdrop-blur-[1px]">
    <div class="container mx-auto px-4 py-6 max-w-5xl">
      
      <!-- 头部区域 -->
      <div class="flex items-center justify-between mb-6 pb-2 border-b border-cyan-500/30 flex-wrap gap-3">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-500 to-purple-500 flex items-center justify-center shadow-lg shadow-cyan-500/25 animate-pulse-glow">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h1 class="text-xl font-semibold tracking-tight bg-gradient-to-r from-cyan-400 to-purple-400 bg-clip-text text-transparent">
            资源仓库
          </h1>
        </div>
        <a href="/AstroNav/" class="text-xs text-slate-400 hover:text-cyan-400 transition flex items-center gap-1 group">
          <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          返回首页
        </a>
      </div>

      <!-- 搜索框 -->
      <div class="mb-6">
        <div class="relative">
          <input 
            type="text" 
            id="searchInput"
            placeholder="🔍 搜索资源标题、描述或分类..."
            class="w-full px-4 py-2.5 pl-10 rounded-xl bg-slate-900/60 backdrop-blur-sm border border-slate-700/50 focus:border-cyan-500/70 focus:outline-none focus:ring-1 focus:ring-cyan-500/50 text-slate-200 placeholder-slate-500 transition-all"
          />
          <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <div id="searchHint" class="mt-2 text-xs text-cyan-400/70 hidden"></div>
      </div>

      <!-- 文件夹列表容器 -->
      <div id="folderContainer" class="space-y-3">
        <div class="text-center py-8 text-slate-400">加载中...</div>
      </div>
      
      <!-- 脚注 -->
      <div class="mt-10 text-center text-xs text-slate-600 border-t border-slate-800/50 pt-6">
        <p>© MaiMaiNav Folder · {categoriesCount} 个分类 · {totalCount} 个精选链接</p>
      </div>
    </div>
  </div>
</FolderLayout>

<!-- 渲染和搜索脚本 -->
<script define:vars={{ safeDataJson, groupedJson }}>
  (function() {
    // 解析数据
    let allItems = [];
    let groupedData = {};
    
    try {
      allItems = JSON.parse(safeDataJson) || [];
      groupedData = JSON.parse(groupedJson) || {};
    } catch (e) {
      console.error('数据解析失败:', e);
    }
    
    console.log('加载数据:', { itemCount: allItems.length, categories: Object.keys(groupedData).length });
    
    const container = document.getElementById('folderContainer');
    const searchInput = document.getElementById('searchInput');
    const searchHint = document.getElementById('searchHint');
    
    if (!container) return;
    
    // 转义 HTML
    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }
    
    // 切换文件夹
    window.toggleFolder = function(btn) {
      const header = btn.closest('.folder-header');
      if (!header) return;
      const content = header.querySelector('.folder-content');
      const icon = header.querySelector('.folder-icon');
      const statusText = header.querySelector('.status-text');
      const isHidden = content.classList.contains('hidden');
      
      if (isHidden) {
        content.classList.remove('hidden');
        if (icon) icon.style.transform = 'rotate(90deg)';
        if (statusText) statusText.textContent = '收起';
      } else {
        content.classList.add('hidden');
        if (icon) icon.style.transform = 'rotate(0deg)';
        if (statusText) statusText.textContent = '展开';
      }
    };
    
    // 渲染列表
    function renderList(keyword) {
      const searchLower = (keyword || '').toLowerCase().trim();
      const hasSearch = searchLower !== '';
      
      // 过滤数据
      let filteredGrouped = {};
      let totalFiltered = 0;
      
      if (!hasSearch) {
        filteredGrouped = groupedData;
        totalFiltered = allItems.length;
      } else {
        for (const [folderName, items] of Object.entries(groupedData)) {
          const filteredItems = items.filter(item => {
            const title = (item.title || '').toLowerCase();
            const desc = (item.description || '').toLowerCase();
            const cat = (item.category || '').toLowerCase();
            return title.includes(searchLower) || desc.includes(searchLower) || cat.includes(searchLower);
          });
          if (filteredItems.length > 0) {
            filteredGrouped[folderName] = filteredItems;
            totalFiltered += filteredItems.length;
          }
        }
      }
      
      // 更新提示
      if (searchHint) {
        if (hasSearch) {
          searchHint.textContent = `找到 ${totalFiltered} 个相关资源`;
          searchHint.classList.remove('hidden');
        } else {
          searchHint.classList.add('hidden');
        }
      }
      
      // 无结果
      if (Object.keys(filteredGrouped).length === 0) {
        container.innerHTML = `
          <div class="text-center py-12 text-slate-400">
            <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p>没有找到相关资源</p>
            <p class="text-sm mt-1">试试其他关键词吧~</p>
          </div>
        `;
        return;
      }
      
      // 生成 HTML
      let html = '';
      for (const [folderName, items] of Object.entries(filteredGrouped)) {
        // 资源项 HTML
        let itemsHtml = '';
        for (const item of items) {
          let domain = '';
          try {
            domain = item.url ? new URL(item.url).hostname : '';
          } catch (e) {
            domain = '';
          }
          const faviconUrl = item.image || `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
          const statusClass = item.status === 'online' ? 'bg-emerald-500' : 'bg-red-500';
          
          itemsHtml += `
            <a 
              href="${item.url || '#'}"
              target="_blank"
              rel="noopener noreferrer" 
              class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-800/50 transition-all group/link"
            >
              <div class="w-6 h-6 rounded flex items-center justify-center bg-slate-800 overflow-hidden flex-shrink-0">
                <img 
                  src="${faviconUrl}"
                  alt="${escapeHtml(item.title)}"
                  class="w-4 h-4 object-cover"
                  onerror="this.style.display='none'"
                />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-slate-200 group-hover/link:text-cyan-400 transition-colors truncate">
                    ${escapeHtml(item.title)}
                  </span>
                  <span class="w-1.5 h-1.5 rounded-full ${statusClass}"></span>
                </div>
                <p class="text-xs text-slate-500 truncate">${escapeHtml(item.description || '点击访问')}</p>
              </div>
              <div class="opacity-0 group-hover/link:opacity-100 transition-all group-hover/link:translate-x-0.5">
                <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
              </div>
            </a>
          `;
        }
        
        // 文件夹区块
        html += `
          <div class="folder-group" data-folder="${escapeHtml(folderName)}">
            <div class="folder-header" data-open="false">
              <button 
                onclick="toggleFolder(this)"
                class="w-full flex items-center gap-3 p-3 rounded-xl bg-slate-900/60 backdrop-blur-sm border border-slate-700/50 hover:border-cyan-500/50 transition-all duration-200 group relative overflow-hidden"
              >
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-cyan-500/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
                <div class="w-6 h-6 flex items-center justify-center text-cyan-400 transition-transform duration-200 folder-icon">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </div>
                <div class="flex-1 text-left">
                  <span class="text-base font-medium text-slate-100">${escapeHtml(folderName)}</span>
                  <span class="ml-2 text-xs text-slate-500">(${items.length})</span>
                </div>
                <div class="text-xs font-mono text-cyan-400/70">
                  <span class="status-text">展开</span>
                </div>
              </button>
              <div class="folder-content mt-2 ml-8 pl-4 space-y-2">
                ${itemsHtml}
              </div>
            </div>
          </div>
        `;
      }
      
      container.innerHTML = html;
    }
    
    // 搜索监听
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        renderList(e.target.value);
      });
    }
    
    // 初始渲染
    if (allItems.length > 0) {
      renderList('');
    } else {
      container.innerHTML = `
        <div class="text-center py-12 text-slate-400">
          <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p>暂无数据，请检查 roomdata.json 文件</p>
        </div>
      `;
    }
  })();
</script>

<!-- 动态渐变背景脚本 -->
<script is:inline>
  (function() {
    const canvas = document.getElementById('gradientCanvas');
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    
    let width = window.innerWidth;
    let height = window.innerHeight;
    let time = 0;
    
    function resizeCanvas() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    }
    
    function drawGradient() {
      time += 0.002;
      
      const grad = ctx.createLinearGradient(
        width * (0.5 + Math.sin(time) * 0.1), 
        height * (0.3 + Math.cos(time * 0.7) * 0.1),
        width * (0.5 + Math.cos(time * 0.5) * 0.1), 
        height * (0.7 + Math.sin(time * 0.8) * 0.1)
      );
      
      grad.addColorStop(0, '#0f0c29');
      grad.addColorStop(0.3, '#1a1a3e');
      grad.addColorStop(0.6, '#1e1b4b');
      grad.addColorStop(1, '#0f0c29');
      
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, width, height);
      
      requestAnimationFrame(drawGradient);
    }
    
    window.addEventListener('resize', resizeCanvas);
    
    resizeCanvas();
    drawGradient();
  })();
</script>

<style is:global>
  html, body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  ::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }
  ::-webkit-scrollbar-track {
    background: #0f172a;
  }
  ::-webkit-scrollbar-thumb {
    background: #2dd4bf;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #14b8a6;
  }
  
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 5px rgba(34, 211, 238, 0.3); }
    50% { box-shadow: 0 0 15px rgba(34, 211, 238, 0.6); }
  }
  .animate-pulse-glow {
    animation: pulse-glow 3s ease-in-out infinite;
  }
</style>