---
// src/pages/folder.astro
import FolderLayout from '../layouts/FolderLayout.astro';
import roomData from '../data/roomdata.json';

interface NavItem {
  id: number;
  category: string;
  title: string;
  description: string;
  tags: string[];
  status: string;
  url: string;
  image: string;
}

const safeData = Array.isArray(roomData) ? roomData : [];

// 按分类分组（用于服务端统计）
const groupedItems = safeData.reduce((acc, item) => {
  const folderName = item.category || '未分类';
  if (!acc[folderName]) acc[folderName] = [];
  acc[folderName].push(item);
  return acc;
}, {} as Record<string, NavItem[]>);

const categoryCounts = Object.fromEntries(
  Object.entries(groupedItems).map(([name, items]) => [name, items.length])
);

const totalCount = safeData.length;
const categoriesCount = Object.keys(groupedItems).length;
const BATCH_SIZE = 100; // 每批加载数量
---

<FolderLayout title="MaiMai · 资源库">
  <!-- 加载指示器 -->
  <div id="loadingIndicator" class="fixed bottom-4 right-4 bg-cyan-500/80 text-white px-3 py-1 rounded-full text-xs hidden z-50">
    加载中...
  </div>
  
  <canvas id="gradientCanvas" class="fixed top-0 left-0 w-full h-full -z-10"></canvas>
  
  <div class="relative z-10 min-h-screen text-slate-200 antialiased backdrop-blur-[1px]">
    <div class="container mx-auto px-4 py-6 max-w-5xl">
      
      <!-- 头部区域 -->
      <div class="flex items-center justify-between mb-6 pb-2 border-b border-cyan-500/30 flex-wrap gap-3">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-500 to-purple-500 flex items-center justify-center shadow-lg shadow-cyan-500/25 animate-pulse-glow">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h1 class="text-xl font-semibold tracking-tight bg-gradient-to-r from-cyan-400 to-purple-400 bg-clip-text text-transparent">
            资源仓库
          </h1>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs text-slate-400 bg-slate-800/50 px-2 py-1 rounded-full">
            📊 {totalCount} 个资源
          </span>
          <a href="/AstroNav/" class="text-xs text-slate-400 hover:text-cyan-400 transition flex items-center gap-1 group">
            <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            返回首页
          </a>
        </div>
      </div>

      <!-- 搜索框 -->
      <div class="mb-6">
        <div class="relative">
          <input 
            type="text" 
            id="searchInput"
            placeholder="🔍 搜索资源..."
            class="w-full px-4 py-2.5 pl-10 rounded-xl bg-slate-900/60 backdrop-blur-sm border border-slate-700/50 focus:border-cyan-500/70 focus:outline-none focus:ring-1 focus:ring-cyan-500/50 text-slate-200 placeholder-slate-500 transition-all"
          />
          <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- 文件夹统计 -->
      <div class="flex flex-wrap gap-2 mb-6">
        {Object.entries(categoryCounts).slice(0, 8).map(([name, count]) => (
          <span class="text-xs bg-slate-800/50 px-2 py-1 rounded-full">{name}: {count}</span>
        ))}
        {Object.keys(categoryCounts).length > 8 && (
          <span class="text-xs bg-slate-800/50 px-2 py-1 rounded-full">
            +{Object.keys(categoryCounts).length - 8} 个分类
          </span>
        )}
      </div>

      <!-- 文件夹列表容器 -->
      <div id="folderContainer" class="space-y-3">
        <div class="text-center py-8 text-slate-400">加载中...</div>
      </div>
      
      <!-- 加载更多按钮 -->
      <div id="loadMoreBtn" class="text-center mt-8 hidden">
        <button onclick="loadMore()" class="px-6 py-2 bg-cyan-500/20 hover:bg-cyan-500/30 border border-cyan-500/50 rounded-lg text-cyan-400 transition-all">
          加载更多资源
        </button>
      </div>
      
      <div class="mt-10 text-center text-xs text-slate-600 border-t border-slate-800/50 pt-6">
        <p>© MaiMaiNav Folder · {categoriesCount} 个分类 · {totalCount} 个精选链接 数据仅供学习参考
          本站所提供的网址和资源均来源于互联网公开渠道，所有链接均指向第三方网盘或网站，
          本站不储存、复制、传播任何文件，其网盘资源文件的完整性需要您自行判断。如有侵犯您的权益，
          请发送相关证明文件至邮箱 maimai977977@gmail.com 及时与我们联系进行屏蔽删除处理！
          谢谢！净网声明 - 版权说明 - 免责声明</p>
      </div>
    </div>
  </div>
</FolderLayout>

<script define:vars={{ safeData: JSON.stringify(safeData), BATCH_SIZE }}>
  // 解析传入的数据
  let fullData = [];
  try {
    fullData = JSON.parse(safeData) || [];
  } catch (e) {
    console.error('数据解析失败:', e);
  }
  
  console.log('总数据量:', fullData.length);
  
  let currentIndex = 0;
  let isLoading = false;
  let allDataLoaded = false;
  
  const batchSize = BATCH_SIZE || 100;
  
  function groupByCategory(data) {
    const grouped = {};
    for (const item of data) {
      const cat = item.category || '未分类';
      if (!grouped[cat]) grouped[cat] = [];
      grouped[cat].push(item);
    }
    return grouped;
  }
  
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }
  
  function renderData(data) {
    const grouped = groupByCategory(data);
    const container = document.getElementById('folderContainer');
    if (!container) return;
    
    if (Object.keys(grouped).length === 0) {
      container.innerHTML = '<div class="text-center py-12 text-slate-400">暂无数据</div>';
      return;
    }
    
    let html = '';
    for (const [folderName, items] of Object.entries(grouped)) {
      let itemsHtml = '';
      for (const item of items) {
        let domain = '';
        try {
          domain = item.url ? new URL(item.url).hostname : '';
        } catch(e) {}
        const faviconUrl = item.image || `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
        
        itemsHtml += `
          <a href="${item.url || '#'}" target="_blank" rel="noopener noreferrer" 
             class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-800/50 transition-all group/link">
            <div class="w-6 h-6 rounded bg-slate-800 flex items-center justify-center overflow-hidden">
              <img src="${faviconUrl}" alt="${escapeHtml(item.title)}" class="w-4 h-4" onerror="this.style.display='none'"/>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-slate-200 group-hover/link:text-cyan-400 truncate">${escapeHtml(item.title)}</span>
                <span class="w-1.5 h-1.5 rounded-full ${item.status === 'online' ? 'bg-emerald-500' : 'bg-red-500'}"></span>
              </div>
              <p class="text-xs text-slate-500 truncate">${escapeHtml(item.description || '点击访问')}</p>
            </div>
            <svg class="w-4 h-4 text-slate-500 group-hover/link:text-cyan-400 group-hover/link:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
        `;
      }
      
      html += `
        <div class="folder-group">
          <div class="folder-header">
            <button onclick="toggleFolder(this)" class="w-full flex items-center gap-3 p-3 rounded-xl bg-slate-900/60 backdrop-blur-sm border border-slate-700/50 hover:border-cyan-500/50 transition-all">
              <div class="w-6 h-6 flex items-center justify-center text-cyan-400 transition-transform folder-icon" style="transform: rotate(0deg)">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </div>
              <div class="flex-1 text-left">
                <span class="text-base font-medium text-slate-100">${escapeHtml(folderName)}</span>
                <span class="ml-2 text-xs text-slate-500">(${items.length})</span>
              </div>
              <div class="text-xs font-mono text-cyan-400/70"><span class="status-text">展开</span></div>
            </button>
            <div class="folder-content mt-2 ml-8 pl-4 space-y-2 hidden">${itemsHtml}</div>
          </div>
        </div>
      `;
    }
    
    container.innerHTML = html;
  }
  
  window.toggleFolder = function(btn) {
    const header = btn.closest('.folder-header');
    const content = header.querySelector('.folder-content');
    const icon = header.querySelector('.folder-icon');
    const statusText = header.querySelector('.status-text');
    const isHidden = content.classList.contains('hidden');
    
    if (isHidden) {
      content.classList.remove('hidden');
      if (icon) icon.style.transform = 'rotate(90deg)';
      if (statusText) statusText.textContent = '收起';
    } else {
      content.classList.add('hidden');
      if (icon) icon.style.transform = 'rotate(0deg)';
      if (statusText) statusText.textContent = '展开';
    }
  };
  
  window.loadMore = function() {
    if (isLoading || allDataLoaded) return;
    isLoading = true;
    
    const loadingEl = document.getElementById('loadingIndicator');
    if (loadingEl) loadingEl.classList.remove('hidden');
    
    setTimeout(() => {
      const newEnd = Math.min(currentIndex + batchSize, fullData.length);
      const newData = fullData.slice(0, newEnd);
      renderData(newData);
      currentIndex = newEnd;
      
      if (currentIndex >= fullData.length) {
        allDataLoaded = true;
        const btn = document.getElementById('loadMoreBtn');
        if (btn) btn.classList.add('hidden');
      }
      
      if (loadingEl) loadingEl.classList.add('hidden');
      isLoading = false;
    }, 100);
  };
  
  // 初始渲染
  if (fullData.length > 0) {
    currentIndex = Math.min(batchSize, fullData.length);
    renderData(fullData.slice(0, currentIndex));
    
    if (fullData.length > batchSize) {
      const btn = document.getElementById('loadMoreBtn');
      if (btn) btn.classList.remove('hidden');
    }
  } else {
    document.getElementById('folderContainer').innerHTML = '<div class="text-center py-12 text-slate-400">暂无数据</div>';
  }
</script>

<style is:global>
  .folder-content.hidden { display: none; }
</style>