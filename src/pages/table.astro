---
// src/pages/table.astro
import TableLayout from '../layouts/TableLayout.astro';
import tableData from '../data/tableData.json';

// 定义数据类型
interface DataItem {
  id: number;
  category: string;
  title: string;
  description: string;
  tags: string[];
  status: string;
  url: string;
  time: string;
  image: string;
}

const allData = tableData as DataItem[];

// 提取所有分类
const categories = ['全部', ...new Set(allData.map(item => item.category))];

const totalCount = allData.length;
---

<TableLayout title="夸克网盘资源库">
  <div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800">
    <div class="container mx-auto px-4 py-6 max-w-7xl">
      
      <!-- 头部导航 -->
      <div class="flex flex-wrap items-center justify-between gap-4 mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex items-center gap-3">
          <a href="/AstroNav/" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 transition">
            ← 返回首页
          </a>
          <h1 class="text-2xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
            📦 网盘资源库
          </h1>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm text-gray-500 dark:text-gray-400">共 {totalCount} 条资源</span>
        </div>
      </div>

      <!-- 主容器 -->
      <div id="app">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
          <div class="flex gap-2">
            <button id="cardViewBtn" class="px-4 py-2 rounded-lg bg-blue-500 text-white transition-all">📇 卡片视图</button>
            <button id="tableViewBtn" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 transition-all">📋 表格视图</button>
          </div>
          <div class="relative">
            <input type="text" id="searchInput" placeholder="🔍 搜索标题、描述..." class="w-64 px-4 py-2 pl-9 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
            <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
        </div>

        <div id="categoryContainer" class="flex flex-wrap gap-2 mb-4"></div>
        <div id="cardContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"></div>
        <div id="tableContainer" class="overflow-x-auto hidden"></div>
        <div id="pagination" class="flex justify-center gap-2 mt-6"></div>
        <div id="noDataMsg" class="text-center py-12 text-gray-500 hidden">
          <svg class="w-12 h-12 mx-auto mb-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p>没有找到相关资源</p>
        </div>
      </div>

      <footer class="mt-8 pt-4 text-center text-xs text-gray-500 dark:text-gray-400 border-t border-gray-200 dark:border-gray-700">
        <p>© 网盘资源库 · 共 {totalCount} 条资源 · 数据仅供学习参考</p>
      </footer>
    </div>
  </div>
</TableLayout>

<script define:vars={{ allData, categories }}>
  // 直接使用 Astro 注入的变量
  let filteredData = [];
  let currentView = 'card';
  let currentCategory = '全部';
  let currentPage = 1;
  const pageSize = 50;
  
  let cardContainer, tableContainer, categoryContainer, paginationDiv, noDataMsg;
  
  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }
  
  function renderCategories() {
    if (!categoryContainer) return;
    let html = '';
    for (let cat of categories) {
      const count = cat === '全部' ? allData.length : allData.filter(item => item.category === cat).length;
      const activeClass = currentCategory === cat ? 'bg-blue-500 text-white' : 'bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300';
      html += `<button class="category-btn px-3 py-1 rounded-full text-sm transition-all ${activeClass}" data-category="${cat}">${escapeHtml(cat)} (${count})</button>`;
    }
    categoryContainer.innerHTML = html;
    
    document.querySelectorAll('.category-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        currentCategory = this.dataset.category;
        currentPage = 1;
        renderCategories();
        updateFilterAndRender();
      });
    });
  }
  
  function updateFilterAndRender() {
    const searchInput = document.getElementById('searchInput');
    const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
    
    filteredData = allData.filter(item => {
      if (currentCategory !== '全部' && item.category !== currentCategory) return false;
      if (searchTerm && !item.title.toLowerCase().includes(searchTerm) && !(item.description && item.description.toLowerCase().includes(searchTerm))) return false;
      return true;
    });
    
    renderCurrentView();
    renderPagination();
  }
  
  function renderCurrentView() {
    if (currentView === 'card') {
      renderCardView();
    } else {
      renderTableView();
    }
  }
  
  function renderCardView() {
    cardContainer.classList.remove('hidden');
    tableContainer.classList.add('hidden');
    noDataMsg.classList.add('hidden');
    
    const start = (currentPage - 1) * pageSize;
    const pageData = filteredData.slice(start, start + pageSize);
    
    if (pageData.length === 0) {
      noDataMsg.classList.remove('hidden');
      cardContainer.innerHTML = '';
      return;
    }
    
    let html = '';
    for (let item of pageData) {
      const statusClass = item.status === 'online' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-gray-100 text-gray-700';
      const imageUrl = item.image || `https://placehold.co/600x400/e2e8f0/64748b?text=${encodeURIComponent(item.title.slice(0, 20))}`;
      
      html += `
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-lg transition-all hover:-translate-y-1">
          <div class="h-32 overflow-hidden bg-gray-100 dark:bg-gray-700">
            <img src="${escapeHtml(imageUrl)}" alt="${escapeHtml(item.title)}" class="w-full h-full object-cover" loading="lazy" onerror="this.src='https://placehold.co/600x400/e2e8f0/64748b?text=No+Image'" />
          </div>
          <div class="p-3">
            <div class="flex items-start justify-between gap-2">
              <h3 class="text-sm font-bold text-gray-800 dark:text-white line-clamp-2 flex-1">${escapeHtml(item.title)}</h3>
              <span class="text-xs px-2 py-0.5 rounded-full ${statusClass}">${item.status === 'online' ? '在线' : '离线'}</span>
            </div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 line-clamp-2">${escapeHtml(item.description || '暂无描述')}</p>
            ${item.time ? `<div class="flex flex-wrap gap-1 mt-2"><span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-500">${escapeHtml(item.time)}</span></div>` : ''}
            <div class="mt-3">
              <a href="${escapeHtml(item.url)}" target="_blank" class="block text-center text-xs py-1.5 px-3 bg-blue-500 hover:bg-blue-600 text-white rounded-lg transition-all">查看资源 →</a>
            </div>
          </div>
        </div>
      `;
    }
    cardContainer.innerHTML = html;
  }
  
  function renderTableView() {
    cardContainer.classList.add('hidden');
    tableContainer.classList.remove('hidden');
    noDataMsg.classList.add('hidden');
    
    const start = (currentPage - 1) * pageSize;
    const pageData = filteredData.slice(start, start + pageSize);
    
    if (pageData.length === 0) {
      noDataMsg.classList.remove('hidden');
      tableContainer.innerHTML = '';
      return;
    }
    
    let html = `<table class="w-full text-sm border-collapse"><thead class="bg-gray-100 dark:bg-gray-800"><tr><th class="px-4 py-2 text-left">ID</th><th class="px-4 py-2 text-left">标题</th><th class="px-4 py-2 text-left hidden md:table-cell">分类</th><th class="px-4 py-2 text-left hidden lg:table-cell">时间</th><th class="px-4 py-2 text-left">操作</th></tr></thead><tbody>`;
    
    for (let item of pageData) {
      html += `<tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800/50">
        <td class="px-4 py-2 text-gray-500">${item.id}</td>
        <td class="px-4 py-2"><div class="font-medium text-gray-800 dark:text-white truncate">${escapeHtml(item.title)}</div><div class="text-xs text-gray-500 truncate">${escapeHtml(item.description || '')}</div></td>
        <td class="px-4 py-2 hidden md:table-cell"><span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">${escapeHtml(item.category)}</span></td>
        <td class="px-4 py-2 hidden lg:table-cell text-gray-500">${item.time || ''}</td>
        <td class="px-4 py-2"><a href="${escapeHtml(item.url)}" target="_blank" class="text-blue-500 hover:text-blue-600 text-sm">访问</a></td>
      </tr>`;
    }
    html += `</tbody></table>`;
    tableContainer.innerHTML = html;
  }
  
  function renderPagination() {
    const totalPages = Math.ceil(filteredData.length / pageSize);
    if (totalPages <= 1) { paginationDiv.innerHTML = ''; return; }
    
    paginationDiv.innerHTML = `<button id="prevPageBtn" class="px-3 py-1 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition">上一页</button>
      <span class="px-4 py-1 text-gray-600 dark:text-gray-400">第 ${currentPage} / ${totalPages} 页 (共 ${filteredData.length} 条)</span>
      <button id="nextPageBtn" class="px-3 py-1 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition">下一页</button>`;
    
    document.getElementById('prevPageBtn')?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderCurrentView(); renderPagination(); } });
    document.getElementById('nextPageBtn')?.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; renderCurrentView(); renderPagination(); } });
  }
  
  function bindEvents() {
    document.getElementById('cardViewBtn')?.addEventListener('click', () => {
      currentView = 'card'; currentPage = 1;
      document.getElementById('cardViewBtn').className = 'px-4 py-2 rounded-lg bg-blue-500 text-white transition-all';
      document.getElementById('tableViewBtn').className = 'px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 transition-all';
      renderCurrentView(); renderPagination();
    });
    document.getElementById('tableViewBtn')?.addEventListener('click', () => {
      currentView = 'table'; currentPage = 1;
      document.getElementById('tableViewBtn').className = 'px-4 py-2 rounded-lg bg-blue-500 text-white transition-all';
      document.getElementById('cardViewBtn').className = 'px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 transition-all';
      renderCurrentView(); renderPagination();
    });
    document.getElementById('searchInput')?.addEventListener('input', () => { currentPage = 1; updateFilterAndRender(); });
  }
  
  // 初始化
  cardContainer = document.getElementById('cardContainer');
  tableContainer = document.getElementById('tableContainer');
  categoryContainer = document.getElementById('categoryContainer');
  paginationDiv = document.getElementById('pagination');
  noDataMsg = document.getElementById('noDataMsg');
  
  renderCategories();
  updateFilterAndRender();
  bindEvents();
</script>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .line-clamp-1 { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
</style>